# SaaS Plugin Marketplace Configuration
PORT=3002
NODE_ENV=production

# Authentication
JWT_SECRET=your-jwt-secret-here
API_SIGNING_KEY=your-api-signing-key-here

# Storage
ARTIFACT_STORAGE_PATH=/var/data/artifacts
DB_CONNECTION_STRING=postgresql://user:pass@localhost:5432/marketplace

# Registry
REGISTRY_URL=https://registry.example.com
REGISTRY_API_KEY=your-registry-key

# Logging
LOG_LEVEL=info
