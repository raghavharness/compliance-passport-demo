# HealthTech Patient API Configuration
PORT=3001
NODE_ENV=production

# PHI Encryption
PHI_ENCRYPTION_KEY=your-256-bit-hex-key-here

# Authentication
JWT_SECRET=your-jwt-secret-here

# Database
DB_CONNECTION_STRING=postgresql://user:pass@localhost:5432/ehr

# External Services
PHARMACY_API_KEY=your-pharmacy-api-key
PHARMACY_API_URL=https://api.pharmacy-partner.com/v1
LAB_RESULTS_API_KEY=your-lab-api-key

# Audit Logging
AUDIT_LOG_LEVEL=info
AUDIT_LOG_DESTINATION=stdout
